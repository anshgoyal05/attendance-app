# Pooled connection (Supabase transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection (Supabase, port 5432 — required for Prisma migrations)
DIRECT_URL="postgresql://postgres:password@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"

# One-time setup endpoint secret
SETUP_SECRET="change-this-setup-secret"
